package oliverTorres;

import java.util.Scanner;

public class SecretWord {

	public static void main(String[] args) {

		Scanner ler = new Scanner(System.in);

		// Lista de palavras
		String[] palavras = { "ROCK", "JAVA", "CODE", "PLAY", "GAME", "NOTE", "SONG", "RIFF", "BAND", "SOLO", "SOFT", "DUMB", "BIKE", "SITE" };

		// Escolher palavra aleatória
		String palavraSecreta = palavras[(int) (Math.random() * palavras.length)];

		String tentativa;
		int tentativas = 6;

		System.out.println("=== JOGO TERMO ===");
		System.out.println("Adivinhe a palavra de 4 letras!");

		for (int i = 1; i <= tentativas; i++) {

			System.out.print("\nTentativa " + i + ": ");
			tentativa = ler.nextLine().toUpperCase();

			if (tentativa.length() != 4) {
				System.out.println("Digite uma palavra com 4 letras!");
				i--;
				continue;
			}

			if (tentativa.equals(palavraSecreta)) {
				System.out.println("🎉 Você acertou a palavra!");
				return;
			}

			for (int j = 0; j < 4; j++) {

				char letraTentativa = tentativa.charAt(j);
				char letraCorreta = palavraSecreta.charAt(j);

				if (letraTentativa == letraCorreta) {
					System.out.print("🟩");
				} else if (palavraSecreta.indexOf(letraTentativa) != -1) {
					System.out.print("🟨");
				} else {
					System.out.print("⬛");
				}
			}

			System.out.println();
		}

		System.out.println("\n❌ Você perdeu!");
		System.out.println("A palavra era: " + palavraSecreta);

		ler.close();
	}
}
